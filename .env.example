# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Nomba API ────────────────────────────────────────

NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=                 # Labeled "Private Key" on Nomba dashboard
NOMBA_ACCOUNT_ID=
NOMBA_ENVIRONMENT=sandbox            # "sandbox" | "production"
NOMBA_SANDBOX_MODE=true              # true = mock, false = real API calls via OAuth
NOMBA_BASE_URL=https://sandbox.nomba.com                      # Override base URL (e.g. https://sandbox.nomba.com)
MAIN_ACCOUNT_ID=                     # Main Nomba account ID for header
SUB_ACCOUNT_ID=                      # Sub-account ID for split/directed payments, checkouts

# ─── Payer Admin Auth (change these) ──────────────────
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=24h

# ─── Webhook ──────────────────────────────────────────
WEBHOOK_SECRET=

# ─── Database (single connection string) ──────────────
# Render provides this automatically via Internal Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/payer

# ─── Cloudinary (image storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
