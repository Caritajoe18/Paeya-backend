# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Nomba API ────────────────────────────────────────
# Leave blank when NOMBA_SANDBOX_MODE=true (default)
NOMBA_API_KEY=
NOMBA_ENVIRONMENT=sandbox            # "sandbox" | "production"
NOMBA_SANDBOX_MODE=true              # true = mock responses, no real auth needed

# ─── Payer Admin Auth (change these) ──────────────────
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=24h

# ─── Webhook ──────────────────────────────────────────
WEBHOOK_SECRET=

# ─── Database (single connection string) ──────────────
# Render provides this automatically via Internal Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/payer

# ─── Cloudinary (image storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
