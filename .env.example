# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Nomba API ────────────────────────────────────────
# To use the real Nomba API (sandbox or production):
#   Set NOMBA_CLIENT_ID and NOMBA_CLIENT_SECRET (OAuth2 client credentials)
#   Set NOMBA_ACCOUNT_ID (your Nomba account ID, required in headers)
#   Set NOMBA_ENVIRONMENT to "sandbox" or "production"
#   Set NOMBA_SANDBOX_MODE=false
# To use mock responses (no network needed):
#   Leave NOMBA_CLIENT_ID and NOMBA_CLIENT_SECRET blank
#   Set NOMBA_SANDBOX_MODE=true
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_ENVIRONMENT=sandbox            # "sandbox" | "production"
NOMBA_SANDBOX_MODE=true              # true = mock, false = real API calls via OAuth
MAIN_ACCOUNT_ID=                     # Main Nomba account ID for checkout
SUB_ACCOUNT_ID=                      # Sub-account ID for split/directed payments

# ─── Payer Admin Auth (change these) ──────────────────
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=24h

# ─── Webhook ──────────────────────────────────────────
WEBHOOK_SECRET=

# ─── Database (single connection string) ──────────────
# Render provides this automatically via Internal Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/payer

# ─── Cloudinary (image storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
