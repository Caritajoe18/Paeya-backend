# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Nomba API ────────────────────────────────────────
# To use the real Nomba sandbox API:
#   Set NOMBA_API_KEY to your sandbox bearer token
#   Set NOMBA_SANDBOX_MODE=false
# To use mock responses (no network needed):
#   Leave NOMBA_API_KEY blank
#   Set NOMBA_SANDBOX_MODE=true
NOMBA_API_KEY=
NOMBA_ENVIRONMENT=sandbox            # "sandbox" | "production"
NOMBA_SANDBOX_MODE=true              # true = mock responses, false = real API calls
MAIN_ACCOUNT_ID=                     # Main Nomba account ID for checkout
SUB_ACCOUNT_ID=                      # Sub-account ID for split/directed payments

# ─── Payer Admin Auth (change these) ──────────────────
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=24h

# ─── Webhook ──────────────────────────────────────────
WEBHOOK_SECRET=

# ─── Database (single connection string) ──────────────
# Render provides this automatically via Internal Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/payer

# ─── Cloudinary (image storage) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
